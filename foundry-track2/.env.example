# Microsoft Foundry — full project endpoint (uses az login)
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# OR the simple flavor: Azure OpenAI endpoint + key
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=

# Optional: image generation deployment for real concept art
AZURE_AI_IMAGE_DEPLOYMENT=
AZURE_OPENAI_IMAGE_API_VERSION=2025-04-01-preview

# Optional future media deployment; gallery currently records video opportunities
# and parks actual video generation unless a project-specific pipeline is added.
AZURE_AI_VIDEO_DEPLOYMENT=
